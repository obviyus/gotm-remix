{
	"name": "gotm-remix",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"build": "bunx react-router build",
		"dev": "./portless.sh",
		"dev:direct": "NODE_ENV=development bun run dev-server.ts",
		"format": "oxfmt --check .",
		"format:write": "oxfmt --write .",
		"lint": "oxlint --type-aware .",
		"lint:fix": "oxlint --type-aware . --fix",
		"schema:sync": "bun run scripts/sync-turso-schema.ts",
		"start": "bun run server.ts",
		"test": "bun test",
		"typecheck": "bunx react-router typegen && tsgo --noEmit -p tsconfig.json",
		"knip": "knip"
	},
	"dependencies": {
		"@hello-pangea/dnd": "^18.0.1",
		"@libsql/client": "^0.17.3",
		"@radix-ui/react-dialog": "1.1.15",
		"@radix-ui/react-label": "2.1.8",
		"@radix-ui/react-scroll-area": "1.2.10",
		"@radix-ui/react-separator": "1.1.8",
		"@radix-ui/react-slot": "1.2.4",
		"@react-router/node": "^8.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"echarts": "^6.1.0",
		"isbot": "^5.1.40",
		"lucide-react": "^1.17.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router": "^8.0.0",
		"string-similarity": "^4.0.4",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@babel/preset-typescript": "^7.29.7",
		"@react-router/dev": "^8.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/bun": "1.3.14",
		"@types/node": "^25.9.1",
		"@types/react": "19.2.16",
		"@types/react-dom": "^19.2.3",
		"@types/string-similarity": "^4.0.2",
		"@typescript/native-preview": "^7.0.0-dev.20260604.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"knip": "^6.15.0",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.68.0",
		"oxlint-tsgolint": "^0.23.0",
		"portless": "^0.14.0",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-babel": "^1.7.3"
	},
	"engines": {
		"node": ">=22.22.0"
	}
